===== Function: say =====
  LDC t1, "hello, i am "
  PRINT, t1, str
  INDEX t2, this, 0
  PRINT, t2, str
  LDC t3, "\n"
  PRINT, t3, str
===== Function: setName =====
  INDEX t5, this, 0
  STORE_INDEX name_, this, 0
===== Function: main =====
  ALLOC t8, Student
  MOV s, t8
  PARAM s
  LDC t9, "Tom"
  PARAM t9
  CALL t10, setName
  PARAM s
  CALL t11, say
  RET
